# =============================================================================
# Rental Market Analyzer — environment configuration
# =============================================================================
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
#
#   cp .env.example .env
#   # then edit .env in your editor
#
# See SETUP.md for where to obtain each key.
# =============================================================================


# ---------------- REQUIRED ---------------------------------------------------
# OpenAI key — powers listing agents (GPT-4o-mini) and photo vision analysis.
OPENAI_API_KEY=your_openai_key_here

# Groq key powers all text LLM nodes (intent routing, elicitation,
# planner, reducer, analyzer). Falls back to OpenAI if not set.
GROQ_API_KEY=your_groq_api_key_here

# SerpAPI — powers the Google search stage (URL discovery) and the search_web
# tool. 100 free searches/month on the free plan.
SERPAPI_API_KEY=your_serpapi_key_here

# Firecrawl — scrapes listing pages and returns structured JSON. 500 free scrapes/mo.
FIRECRAWL_API_KEY=your_firecrawl_key_here


# ---------------- REQUIRED FOR COMMUTE / PLACES TOOLS ------------------------
# Single key covers Distance Matrix + Places + Geocoding. You must ENABLE all
# three APIs on the same Google Cloud project or requests return REQUEST_DENIED.
# $200/month free credit from Google.
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Vite: copy frontend/.env.example to frontend/.env and set the same value.
# (the listing map embeds this; Vite does not read this root .env file).


# ---------------- OPTIONAL: LangSmith tracing --------------------------------
# Set LANGCHAIN_TRACING_V2=true to stream per-node traces to LangSmith. The
# other two vars are only read when tracing is on. Free personal tier works.
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=rental-market-analyzer


# ---------------- OPTIONAL: local overrides ----------------------------------
# LLM provider for text nodes: groq (default) or anthropic.
LLM_PROVIDER=groq
# Per-role model override JSON; leave empty for defaults in graph/llm.py.
# Example:
# RENTAL_MODELS={"planner":{"model":"llama-3.3-70b-versatile","temperature":0.2}}
# RENTAL_MODELS=

# Listing-agent parallelism cap (global semaphore across listing agents).
LISTING_CONCURRENCY=3

# Max photos sent to vision model in one listing analysis call.
MAX_PHOTOS=12

# Path to the SQLite checkpointer database file. Default: ./rental_state.db
# Delete this file to reset all conversation state.
# RENTAL_CHECKPOINT_DB=rental_state.db
