# copy this to .env and fill in your keys
# never commit .env to git

ANTHROPIC_API_KEY=your_anthropic_key_here
SERPAPI_API_KEY=your_serpapi_key_here
FIRECRAWL_API_KEY=your_firecrawl_key_here

# LangSmith — set LANGCHAIN_TRACING_V2=true to enable tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=rental-market-analyzer

# Google Maps Platform — single key for Distance Matrix, Places, and Geocoding APIs
# Enable all three APIs in your GCP project, then add the key here
# Used by: get_commute_time (graph/tools/commute.py), find_nearby_places (graph/tools/places.py)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
